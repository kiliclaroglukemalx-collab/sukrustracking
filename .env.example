# Prisma - PostgreSQL bağlantısı
#
# Yerel Docker (önerilen):
#   docker compose up -d
#   Sonra bu URL'i kullanın:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sukrustracking"
#
# Alternatif: Supabase/Neon/Railway — yeni proje oluşturup connection string alın
# DATABASE_URL="postgresql://..."

# Tek seferlik: Eski DB'den veri taşımak için (pnpm db:migrate-from-old)
# Migration sonrası silebilirsiniz.
# OLD_DATABASE_URL="postgresql://..."

# Telegram Bot (opsiyonel)
# Bot: telegram-bot/ klasorunde, pnpm install && pnpm dev
BOT_API_KEY=idils-bot-secret-2026
